# DevGordon configuration
# Copy this file to .env and fill in your values:  cp .env.example .env

# ── Ollama (runs on host, not in Docker) ──────────────────────────────────────
# Change this if Ollama is running somewhere other than localhost
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen3:8b

# ── Kubernetes ────────────────────────────────────────────────────────────────
# Path to kubeconfig on your host machine (default works for most setups)
HOST_KUBECONFIG=~/.kube/config

# Set this only if your kubeconfig points to 127.0.0.1 and kubectl can't reach it
# from inside the container (common with minikube on Linux)
KUBE_API_SERVER=https://host.docker.internal:52137

# ── Jenkins (optional) ────────────────────────────────────────────────────────
# Only needed if you want DevGordon to trigger Jenkins jobs
# Get this from: Jenkins → Manage Jenkins → Security → Create API Token
JENKINS_TOKEN=

# ── SonarQube (optional) ──────────────────────────────────────────────────────
# Only needed for full Python code scanning in the CI pipeline
SONAR_TOKEN=